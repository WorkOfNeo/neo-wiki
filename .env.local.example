# For local dev: use Railway's PUBLIC Postgres URL with ?sslmode=require appended.
# In production (Railway service env), set DATABASE_URL=${{Postgres.DATABASE_PRIVATE_URL}}
# which uses the internal *.railway.internal host and doesn't need sslmode.
DATABASE_URL=
OPENAI_API_KEY=
WIKI_BEARER_TOKEN=
WIKI_BASE_URL=http://localhost:3000
